        <h2 align="center"><button><</button>June<button>></button></h2>
    </div>
    <div>
        <table align="center", cellpadding="25", cellspacing="25">
            <thead>
                <tr>
                    <th>Mon </th>
                    <th>Tues </th>
                    <th>Wed </th>
                    <th>Thurs </th>
                    <th>Fri </th>
                    <th>Sat </th>
                    <th>Sun </th>
                </tr>
            </thead>
            <tbody>
                <tr>
                    <td role="button" onclick="showTask(1)">1</td>
                    <td role="button" onclick="showTask(2)">2</td>
                    <td>3</td>
