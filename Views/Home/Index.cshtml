                    <td>5</td>
                </tr>
            </tbody>
        </table>
    </div>
    <div class="taskBox" id="taskBox">
        <p>Hello task box</p>
    </div>
</div>
<script>
    const tasks={
        1: {title: "Team meeting", details:"1000am"},
        2: {title: "team building event", details:"11:30am"}
    };

    function showTask(day){
        const taskBox = document.getElementById('taskBox');
        const dayTask = tasks[day];

        if (dayTask){
            taskBox.innerHTML = `<h3>${dayTask.title}</h3><p>${dayTask.details}</p>`;
        } 
        else {
            taskBox.innerHTML = `<p>No tasks for day ${day}</p>`;
        }
    }
</script>